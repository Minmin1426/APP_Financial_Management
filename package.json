{
  "name": "app-financial-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"frontend,backend\" -c \"bgBlue,bgGreen\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix server run dev",
    "build": "tsc -b && vite build",
    "build:backend": "npm --prefix server run build",
    "db:init": "npm --prefix server run db:init",
    "lint": "oxlint",
    "test": "jest",
    "preview": "vite preview"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^0.469.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.16.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "oxlint": "^1.69.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
